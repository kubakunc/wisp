VITE_RC_API_KEY=goog_your_revenuecat_public_sdk_key
# Base URL of the bucket hosting downloadable (non-bundled) sounds.
# `file` in sounds.json is just the path within this bucket; the app fetches
# `<VITE_SOUND_CDN>/<file>`. Leave unset to fall back to local static/sounds in dev.
VITE_SOUND_CDN=https://storage.googleapis.com/your-bucket/
